{
  "entities": {
    "Course": {
      "title": "Course",
      "description": "A training course",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string", "enum": ["external_physical", "external_online", "internal_digital", "internal_physical"] },
        "date": { "type": "string" },
        "endDate": { "type": "string" },
        "time": { "type": "string" },
        "location": { "type": "string" },
        "link": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["title", "category", "description"]
    },
    "Registration": {
      "title": "Registration",
      "description": "A user's registration for a course",
      "type": "object",
      "properties": {
        "department": { "type": "string" },
        "employeeId": { "type": "string" },
        "name": { "type": "string" },
        "courseId": { "type": "string" },
        "status": { "type": "string", "enum": ["registered"] },
        "timestamp": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["department", "employeeId", "name", "courseId", "status", "timestamp", "userId"]
    },
    "User": {
      "title": "User",
      "description": "A user profile",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["employee", "admin"] }
      },
      "required": ["name", "email", "role"]
    }
  },
  "firestore": {
    "/courses/{courseId}": {
      "schema": { "$ref": "#/entities/Course" },
      "description": "Collection of all courses"
    },
    "/registrations/{registrationId}": {
      "schema": { "$ref": "#/entities/Registration" },
      "description": "Collection of all course registrations"
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Collection of user profiles"
    }
  }
}
